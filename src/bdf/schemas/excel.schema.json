{
  "$id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/schemas/excel.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Configuration for Excel parsing.",
  "properties": {
    "drop_empty_rows": {
      "type": "boolean"
    },
    "engine": {
      "type": "string"
    },
    "header": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      ]
    },
    "header_row": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "items": {
            "minimum": 1,
            "type": "integer"
          },
          "type": "array"
        }
      ]
    },
    "nrows": {
      "minimum": 1,
      "type": "integer"
    },
    "rename": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "sheet": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "minimum": 0,
          "type": "integer"
        }
      ]
    },
    "sheet_index": {
      "minimum": 1,
      "type": "integer"
    },
    "sheet_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "minimum": 0,
          "type": "integer"
        }
      ]
    },
    "skiprows": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      ]
    },
    "strip_headers": {
      "type": "boolean"
    },
    "usecols": {
      "type": "string"
    },
    "worksheet": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "minimum": 0,
          "type": "integer"
        }
      ]
    }
  },
  "title": "BDF Excel config",
  "type": "object"
}
