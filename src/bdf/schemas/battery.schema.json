{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/schemas/battery.schema.json",
  "title": "BDF battery.json",
  "description": "Battery metadata sidecar for BDF ingest.",
  "type": ["object", "array"],
  "oneOf": [
    {
      "type": "object",
      "required": ["cells"],
      "properties": {
        "schema_version": {
          "type": "string",
          "default": "1.0.0"
        },
        "battery_model": {
          "type": "string",
          "format": "uri"
        },
        "spec": { "$ref": "#/$defs/BatterySpecV1" },
        "cells": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/CellEntry" }
        }
      },
      "additionalProperties": true
    },
    {
      "type": "array",
      "items": { "$ref": "#/$defs/BatteryItem" }
    },
    {
      "type": "object",
      "required": ["ids"],
      "properties": {
        "spec": { "$ref": "#/$defs/BatterySpec" },
        "ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/BatteryIdEntry" }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  ],
  "$defs": {
    "ManufacturerRef": {
      "anyOf": [
        { "type": "string" },
        {
          "type": "object",
          "properties": {
            "@id": { "type": "string", "format": "uri" },
            "name": { "type": "string" }
          },
          "additionalProperties": true
        }
      ]
    },
    "CellEntry": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "cell_id": { "type": "string" },
            "id": { "type": "string" },
            "iri": { "type": "string", "format": "uri" }
          },
          "additionalProperties": true
        }
      ]
    },
    "BatterySpecV1": {
      "type": "object",
      "properties": {
        "manufacturer": { "$ref": "#/$defs/ManufacturerRef" },
        "productID": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "integer" },
        "iec_code": { "type": "string" },
        "chemistry": { "type": "string" },
        "form_factor": { "type": "string" },
        "nominal_voltage_v": { "type": "number" },
        "rated_capacity_ah": { "type": "number" },
        "rated_energy_wh": { "type": "number" },
        "mass_g": { "type": "number" },
        "volume_l": { "type": "number" },
        "pe_materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ne_materials": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "BatterySpec": {
      "type": "object",
      "properties": {
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "batch": { "type": "string" },
        "namespace": { "type": "string", "format": "uri" },
        "name_template": { "type": "string" },
        "iri_template": { "type": "string" },
        "iec_code": { "type": "string" },
        "chemistry": { "type": "string" },
        "form_factor": { "type": "string" },
        "nominal_voltage_v": { "type": "number" },
        "rated_capacity_ah": { "type": "number" },
        "rated_energy_wh": { "type": "number" },
        "mass_g": { "type": "number" },
        "volume_l": { "type": "number" },
        "pe_materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ne_materials": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "BatteryIdEntry": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "short_id": { "type": "string" },
        "full_id": { "type": "string" },
        "name": { "type": "string" },
        "iri": { "type": "string", "format": "uri" }
      },
      "anyOf": [
        { "required": ["id"] },
        { "required": ["short_id"] }
      ],
      "additionalProperties": true
    },
    "BatteryItem": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "iri": { "type": "string", "format": "uri" },
        "battery_model": { "type": "string", "format": "uri" },
        "productID": { "type": "string" },
        "model": { "type": "string" },
        "name": { "type": "string" },
        "manufacturer": { "type": "string" },
        "chemistry": { "type": "string" },
        "iec_code": { "type": "string" },
        "form_factor": { "type": "string" },
        "nominal_voltage_v": { "type": "number" },
        "rated_capacity_ah": { "type": "number" },
        "rated_energy_wh": { "type": "number" },
        "mass_g": { "type": "number" },
        "volume_l": { "type": "number" },
        "pe_materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ne_materials": {
          "type": "array",
          "items": { "type": "string" }
        },
        "batch": { "type": "string" },
        "namespace": { "type": "string", "format": "uri" },
        "name_template": { "type": "string" },
        "iri_template": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
