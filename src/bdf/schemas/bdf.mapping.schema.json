{
  "$id": "https://w3id.org/battery-data-alliance/ontology/battery-data-format/schemas/bdf.mapping.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Mapping file for source files. Target BDF quantities should be used as keys.",
  "properties": {
    "columns": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ]
      },
      "type": "object"
    },
    "data_path": {
      "type": "string"
    },
    "datetime": {
      "additionalProperties": true,
      "properties": {
        "format": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "tz": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "datetime_format": {
      "type": "string"
    },
    "datetime_source": {
      "type": "string"
    },
    "datetime_target": {
      "type": "string"
    },
    "datetime_timezone": {
      "type": "string"
    },
    "datetime_tz": {
      "type": "string"
    },
    "fields": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          {
            "additionalProperties": true,
            "properties": {
              "source": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  }
                ]
              },
              "source_unit": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              }
            },
            "required": [
              "source"
            ],
            "type": "object"
          }
        ]
      },
      "description": "Target quantity -> source binding.",
      "type": "object"
    },
    "map": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ]
      },
      "type": "object"
    },
    "offset": {
      "additionalProperties": {
        "type": "number"
      },
      "type": "object"
    },
    "scale": {
      "additionalProperties": {
        "type": "number"
      },
      "type": "object"
    },
    "schema_version": {
      "type": "string"
    },
    "source_locator": {
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "sheet_name",
              "sheet_index"
            ]
          }
        }
      ],
      "description": "Optional source table selector, mainly for tabular formats like Excel.",
      "properties": {
        "header_row": {
          "minimum": 1,
          "type": "integer"
        },
        "nrows": {
          "minimum": 1,
          "type": "integer"
        },
        "sheet_index": {
          "minimum": 1,
          "type": "integer"
        },
        "sheet_name": {
          "type": "string"
        },
        "skiprows": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "items": {
                "minimum": 0,
                "type": "integer"
              },
              "type": "array"
            }
          ]
        },
        "usecols": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "source_units": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "timestamp": {
      "additionalProperties": true,
      "properties": {
        "format": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        },
        "tz": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "timestamp_format": {
      "type": "string"
    },
    "timestamp_source": {
      "type": "string"
    },
    "timestamp_target": {
      "type": "string"
    },
    "timestamp_timezone": {
      "type": "string"
    },
    "timestamp_tz": {
      "type": "string"
    },
    "units": {
      "additionalProperties": {
        "type": "string"
      },
      "type": "object"
    },
    "variables": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        ]
      },
      "type": "object"
    }
  },
  "title": "BDF mapping sidecar",
  "type": "object"
}
